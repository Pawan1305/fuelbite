# Environment variables for local development
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Admin credentials (set these in Netlify Dashboard → Site Settings → Environment Variables)
ADMIN_USER=admin
ADMIN_PASS=your-strong-password-here

# Random secret for session tokens (generate with: openssl rand -hex 32)
AUTH_SECRET=replace-with-random-64-char-hex-string

# WhatsApp notification (CallMeBot - free)
# See: https://www.callmebot.com/blog/free-api-whatsapp-messages/
WHATSAPP_PHONE=91XXXXXXXXXX
CALLMEBOT_API_KEY=your-callmebot-api-key
